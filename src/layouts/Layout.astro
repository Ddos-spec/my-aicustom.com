---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
	keywords?: string;
}

const { title, description, keywords } = Astro.props;
const siteOrigin = 'https://my-aicustom.com';
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const defaultDescription = "Jasa pengembangan AI Agentic Custom untuk bisnis di Indonesia. Implementasi AI agent, chatbot AI, automation, analytics, dan computer vision dengan ROI terukur.";
const finalDescription = description || defaultDescription;
const defaultKeywords = "jasa AI Indonesia, pengembangan AI Agentic Custom, implementasi AI bisnis, AI agent Indonesia, chatbot AI Agentic Custom, AI automation Indonesia, konsultan AI Indonesia";
const finalKeywords = keywords || defaultKeywords;
const faviconHref = '/favicon.svg';
const socialImage = `${siteOrigin}/assets/og-default.svg`;
const whatsappNumber = '6282121292938';
const whatsappMessage = encodeURIComponent('Halo kak saya mau coba konsultasi ai agentic custom');
const orgJsonLd = JSON.stringify({
	"@context": "https://schema.org",
	"@type": ["Organization", "LocalBusiness"],
	"name": "my-aicustom.com",
	"alternateName": "My AI Agentic Custom",
	"url": siteOrigin,
	"logo": `${siteOrigin}/assets/og-default.svg`,
	"image": `${siteOrigin}/assets/og-default.svg`,
	"description": "Perusahaan jasa pengembangan AI Agentic Custom di Indonesia untuk implementasi AI agent, chatbot, automation, analytics, dan computer vision.",
	"address": {
		"@type": "PostalAddress",
		"addressCountry": "ID",
		"addressLocality": "Indonesia"
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": "-6.2088",
		"longitude": "106.8456"
	},
	"contactPoint": [{
		"@type": "ContactPoint",
		"telephone": "+62-821-2129-2938",
		"contactType": "Customer Service",
		"areaServed": "ID",
		"availableLanguage": ["Indonesian", "English"]
	}],
	"sameAs": [
		"https://www.linkedin.com/company/my-aicustom",
		"https://www.facebook.com/myaicustom",
		"https://twitter.com/myaicustom",
		"https://www.instagram.com/myaicustom"
	],
	"aggregateRating": {
		"@type": "AggregateRating",
		"ratingValue": "4.9",
		"reviewCount": "127"
	},
	"priceRange": "$$",
	"openingHours": "Mo-Fr 09:00-18:00",
	"email": "myaicustom@gmail.com",
	"founder": {
		"@type": "Person",
		"name": "Dion Hartono"
	},
	"foundingDate": "2023",
	"keywords": "jasa AI Indonesia, pengembangan AI Agentic Custom, implementasi AI bisnis, AI agent Indonesia, AI automation",
	"serviceType": "Jasa Pengembangan AI Agentic Custom",
	"areaServed": {
		"@type": "Country",
		"name": "Indonesia"
	}
}, null, 2);
---

<!doctype html>
<html lang="id" class="scroll-smooth">
        <head>
                <!-- Google tag (gtag.js) -->
                <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17719750160"></script>
                <script is:inline>
                  window.dataLayer = window.dataLayer || [];
                  function gtag(){dataLayer.push(arguments);}
                  gtag('js', new Date());

                  gtag('config', 'AW-17719750160');
                </script>
                <meta charset="UTF-8" />
                <title>{title}</title>
                <meta name="description" content={finalDescription} />
                <meta name="keywords" content={finalKeywords} />
                <meta name="viewport" content="width=device-width, initial-scale=1" />
                <meta name="theme-color" content="#f8fbff" />
                <link rel="preconnect" href="https://fonts.googleapis.com" />
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
                <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Sora:wght@500;600;700&display=swap" rel="stylesheet" />
                <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
                <meta name="googlebot" content="index, follow" />
                <meta name="language" content="Indonesian" />
                <meta name="geo.region" content="ID" />
                <meta name="geo.placename" content="Indonesia" />
                <meta name="author" content="my-aicustom.com" />
                <link rel="icon" type="image/svg+xml" href={faviconHref} />
                <link rel="canonical" href={canonicalUrl} />
                <meta name="generator" content={Astro.generator} />
                <meta http-equiv="X-UA-Compatible" content="IE=edge" />

                <!-- Open Graph / Facebook -->
                <meta property="og:type" content="website" />
                <meta property="og:url" content={canonicalUrl} />
                <meta property="og:title" content={title} />
                <meta property="og:description" content={finalDescription} />
                <meta property="og:image" content={socialImage} />
                <meta property="og:image:width" content="1200" />
                <meta property="og:image:height" content="630" />
                <meta property="og:locale" content="id_ID" />
                <meta property="og:site_name" content="my-aicustom.com" />

                <!-- Twitter -->
                <meta name="twitter:card" content="summary_large_image" />
                <meta name="twitter:url" content={canonicalUrl} />
                <meta name="twitter:title" content={title} />
                <meta name="twitter:description" content={finalDescription} />
                <meta name="twitter:image" content={socialImage} />
                <meta name="twitter:site" content="@myaicustom" />
                <meta name="twitter:creator" content="@myaicustom" />

                <!-- Schema.org markup for Google+ -->
                <script type="application/ld+json">{orgJsonLd}</script>

                <!-- Additional schemas from pages -->
                <slot name="head" />

                <!-- View Transitions for smooth page navigation -->
                <ViewTransitions />

                <style>
                        :root {
                                --surface-ivory: #f6f9ff;
                                --ink: #14213f;
                                --font-display: 'Sora', 'Segoe UI', sans-serif;
                                --font-body: 'Manrope', 'Segoe UI', sans-serif;
                        }

                        html {
                                scroll-behavior: smooth;
                                background: var(--surface-ivory);
                                color-scheme: light;
                        }

                        body.site-shell {
                                font-family: var(--font-body);
                                color: var(--ink);
                                overflow-x: clip;
                                background:
                                        radial-gradient(circle at 6% -8%, rgba(14, 93, 245, 0.16), transparent 42%),
                                        radial-gradient(circle at 92% 3%, rgba(55, 131, 255, 0.14), transparent 38%),
                                        linear-gradient(180deg, #f8fbff 0%, #f4f8ff 44%, #ffffff 100%);
                        }

                        body.site-shell :is(h1, h2, h3, h4, h5, h6) {
                                font-family: var(--font-display);
                                letter-spacing: -0.012em;
                        }

                        body.site-shell.motion-ready [data-reveal] {
                                opacity: 0;
                                filter: blur(var(--reveal-blur, 8px));
                                transform: translate3d(calc(var(--reveal-x, 0px) + var(--parallax-x-shift, 0px)), calc(var(--reveal-y, 26px) + var(--parallax-shift, 0px)), 0) rotate(var(--parallax-rotate, 0deg)) scale(calc(var(--reveal-scale, 0.985) + var(--parallax-scale, 0)));
                                transition:
                                        opacity 720ms cubic-bezier(0.22, 1, 0.36, 1),
                                        transform 980ms cubic-bezier(0.22, 1, 0.36, 1),
                                        filter 820ms cubic-bezier(0.22, 1, 0.36, 1);
                                transition-delay: var(--reveal-delay, 0ms);
                                will-change: transform, opacity, filter;
                        }

                        body.site-shell.motion-ready [data-reveal].is-visible {
                                opacity: 1;
                                filter: blur(0px);
                                transform: translate3d(var(--parallax-x-shift, 0px), var(--parallax-shift, 0px), 0) rotate(var(--parallax-rotate, 0deg)) scale(calc(1 + var(--parallax-scale, 0)));
                        }

                        body.site-shell.motion-ready [data-reveal='left'] {
                                --reveal-x: -112px;
                                --reveal-y: 0px;
                                --reveal-blur: 10px;
                        }

                        body.site-shell.motion-ready [data-reveal='right'] {
                                --reveal-x: 112px;
                                --reveal-y: 0px;
                                --reveal-blur: 10px;
                        }

                        body.site-shell.motion-ready [data-reveal='up'] {
                                --reveal-y: 72px;
                                --reveal-blur: 8px;
                        }

                        body.site-shell.motion-ready [data-reveal='scale'] {
                                --reveal-y: 28px;
                                --reveal-scale: 0.9;
                                --reveal-blur: 10px;
                        }

                        body.site-shell.motion-lite [data-reveal] {
                                filter: none;
                                transition:
                                        opacity 520ms cubic-bezier(0.22, 1, 0.36, 1),
                                        transform 680ms cubic-bezier(0.22, 1, 0.36, 1);
                        }

                        body.site-shell.motion-lite [data-reveal='left'],
                        body.site-shell.motion-lite [data-reveal='right'] {
                                --reveal-x: 0px;
                                --reveal-y: 26px;
                                --reveal-blur: 0px;
                        }

                        body.site-shell.motion-lite [data-reveal='up'] {
                                --reveal-y: 24px;
                                --reveal-blur: 0px;
                        }

                        body.site-shell.motion-lite [data-reveal='scale'] {
                                --reveal-y: 18px;
                                --reveal-scale: 0.97;
                                --reveal-blur: 0px;
                        }

                        @media (max-width: 900px) {
                                body.site-shell.motion-ready [data-reveal='left'],
                                body.site-shell.motion-ready [data-reveal='right'] {
                                        --reveal-x: 0px;
                                        --reveal-y: 34px;
                                        --reveal-blur: 6px;
                                }
                        }

                        /* Performance guard for lower-end laptops and mobile devices */
                        @media (max-width: 1366px) {
                                [class*='backdrop-blur'] {
                                        -webkit-backdrop-filter: none !important;
                                        backdrop-filter: none !important;
                                }

                                [class*='shadow-['],
                                .shadow-2xl,
                                .shadow-xl,
                                .shadow-lg {
                                        box-shadow: 0 10px 24px -16px rgba(15, 23, 42, 0.35) !important;
                                }
                        }

                        @media (prefers-reduced-motion: reduce) {
                                *,
                                *::before,
                                *::after {
                                        animation-duration: 0.01ms !important;
                                        animation-iteration-count: 1 !important;
                                        transition-duration: 0.01ms !important;
                                }

                                html {
                                        scroll-behavior: auto;
                                }
                        }
                </style>
        </head>
        <body class="site-shell bg-white text-gray-800 pt-16">
                <Header />
                <main>
                        <slot />
                </main>
                <Footer />
                <a
                        href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="fixed bottom-6 right-6 z-50 inline-flex items-center gap-2 rounded-full bg-green-500 px-4 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-green-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-green-500"
                        aria-label="Hubungi kami via WhatsApp"
                >
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M20 3H4a1 1 0 00-1 1v16l4-4h13a1 1 0 001-1V4a1 1 0 00-1-1z" />
                        </svg>
                        <span>WhatsApp</span>
                </a>
                <script is:inline>
                        (() => {
                                const cleanupKey = '__siteMotionCleanup';
                                const reduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;
                                const liteMotion = () => {
                                        const saveData = navigator.connection && navigator.connection.saveData;
                                        const narrowViewport = window.matchMedia('(max-width: 900px)').matches;
                                        const coarsePointer = window.matchMedia('(pointer: coarse)').matches;
                                        const lowMemory = typeof navigator.deviceMemory === 'number' && navigator.deviceMemory <= 4;
                                        const lowCpu = typeof navigator.hardwareConcurrency === 'number' && navigator.hardwareConcurrency <= 4;

                                        return Boolean(saveData || (narrowViewport && coarsePointer) || lowMemory || lowCpu);
                                };
                                const bind = (el, type = 'up', delay = 0, parallax = 0, axis = 'y', direction = 1, media = false) => {
                                        if (!el) return;
                                        if (!el.dataset.reveal) el.dataset.reveal = type;
                                        if (!el.style.getPropertyValue('--reveal-delay') && delay) el.style.setProperty('--reveal-delay', `${delay}ms`);
                                        if (!el.dataset.parallax && parallax) el.dataset.parallax = String(parallax);
                                        if (!el.dataset.parallaxAxis && axis) el.dataset.parallaxAxis = axis;
                                        if (!el.dataset.parallaxDirection) el.dataset.parallaxDirection = String(direction);
                                        if (media) el.dataset.parallaxMedia = 'true';
                                };
                                const setupMotion = () => {
                                        window[cleanupKey]?.();
                                        if (reduceMotion()) return;
                                        const isLiteMotion = liteMotion();
                                        document.body.classList.add('motion-ready');
                                        document.body.classList.toggle('motion-lite', isLiteMotion);
                                        document.querySelectorAll('.reveal-left, .reveal-right, .reveal-up, .reveal-scale').forEach((el) => {
                                                const type = [...el.classList].find((name) => name.startsWith('reveal-'))?.replace('reveal-', '') || 'up';
                                                const delayClass = [...el.classList].find((name) => /^delay-\d+$/.test(name));
                                                const hasMedia = !!el.querySelector('img, picture, video');
                                                const axis = hasMedia && (type === 'left' || type === 'right') ? 'x' : 'y';
                                                const parallax = isLiteMotion ? 0 : (hasMedia ? (type === 'scale' ? 104 : 92) : (type === 'up' ? 28 : 42));
                                                const direction = type === 'left' ? -1 : 1;
                                                bind(el, type, delayClass ? Number(delayClass.split('-')[1]) : 0, parallax, axis, direction, hasMedia);
                                        });
                                        document.querySelectorAll('main section').forEach((section) => {
                                                const containers = [...section.querySelectorAll(':scope > .grid, :scope > .flex, :scope > div, :scope > div > .grid, :scope > div > .flex')].filter((node) => {
                                                        const classes = typeof node.className === 'string' ? node.className : '';
                                                        return classes.includes('grid') || classes.includes('flex');
                                                });
                                                const primary = containers.find((container) => [...container.children].filter((child) => child.matches('div, article, aside, blockquote')).length >= 2);
                                                const hasExplicit = section.querySelector('[data-reveal], .reveal-left, .reveal-right, .reveal-up, .reveal-scale');
                                                if (primary) {
                                                        [...primary.children]
                                                                .filter((child) => child.matches('div, article, aside, blockquote'))
                                                                .slice(0, 6)
                                                                .forEach((child, index) => {
                                                                        const type = index % 2 === 0 ? 'left' : 'right';
                                                                        const hasMedia = !!child.querySelector('img, picture, video');
                                                                        const axis = hasMedia ? 'x' : 'y';
                                                                        const parallax = isLiteMotion ? 0 : (hasMedia ? 86 : (index < 2 ? 34 : 22));
                                                                        const direction = type === 'left' ? -1 : 1;
                                                                        bind(child, type, index * 90, parallax, axis, direction, hasMedia);
                                                                });
                                                } else if (!hasExplicit) {
                                                        bind(section, 'up', 0, 12, 'y', 1);
                                                }
                                        });
                                        const revealItems = [...document.querySelectorAll('[data-reveal]')];
                                        const observer = new IntersectionObserver((entries) => {
                                                entries.forEach((entry) => {
                                                        if (!entry.isIntersecting) return;
                                                        entry.target.classList.add('is-visible');
                                                        observer.unobserve(entry.target);
                                                });
                                        }, { threshold: 0.2, rootMargin: '0px 0px -4% 0px' });
                                        revealItems.forEach((item) => observer.observe(item));
                                        const parallaxItems = revealItems.filter((item) => Number(item.dataset.parallax || 0) > 0);
                                        let frame = 0;
                                        const updateParallax = () => {
                                                frame = 0;
                                                const viewportHeight = window.innerHeight || 1;
                                                parallaxItems.forEach((item) => {
                                                        const distance = Number(item.dataset.parallax || 0);
                                                        const axis = item.dataset.parallaxAxis || 'y';
                                                        const direction = Number(item.dataset.parallaxDirection || 1);
                                                        const media = item.dataset.parallaxMedia === 'true';
                                                        const rect = item.getBoundingClientRect();
                                                        if (rect.bottom < 0 || rect.top > viewportHeight) return;
                                                        const center = rect.top + rect.height / 2;
                                                        const progress = (center - viewportHeight / 2) / viewportHeight;
                                                        const shift = Math.max(-distance, Math.min(distance, progress * -distance * 2.7));
                                                        const strength = distance ? shift / distance : 0;
                                                        item.style.setProperty('--parallax-shift', axis === 'y' ? `${shift.toFixed(1)}px` : '0px');
                                                        item.style.setProperty('--parallax-x-shift', axis === 'x' ? `${(shift * direction).toFixed(1)}px` : '0px');
                                                        item.style.setProperty('--parallax-rotate', media ? `${(strength * (axis === 'x' ? 4.8 : 2.4) * direction).toFixed(2)}deg` : '0deg');
                                                        item.style.setProperty('--parallax-scale', media ? `${(Math.abs(strength) * 0.05).toFixed(3)}` : '0');
                                                });
                                        };
                                        const queueParallax = () => {
                                                if (frame) return;
                                                frame = window.requestAnimationFrame(updateParallax);
                                        };
                                        queueParallax();
                                        window.addEventListener('scroll', queueParallax, { passive: true });
                                        window.addEventListener('resize', queueParallax);
                                        window[cleanupKey] = () => {
                                                observer.disconnect();
                                                window.removeEventListener('scroll', queueParallax);
                                                window.removeEventListener('resize', queueParallax);
                                                if (frame) window.cancelAnimationFrame(frame);
                                        };
                                };
                                if (document.readyState === 'loading') {
                                        document.addEventListener('DOMContentLoaded', setupMotion, { once: true });
                                } else {
                                        setupMotion();
                                }
                                document.addEventListener('astro:page-load', setupMotion);
                        })();
                </script>
        </body>
</html>


