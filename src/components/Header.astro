---
const homeHref = '/';
const serviceHref = '/service/';
const adsHref = '/landing-page-ads/';
const blogHref = '/blog/';
const contactHref = '/contact/';
---
<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4 sm:px-6">
  <nav class="mx-auto max-w-screen-xl rounded-2xl border border-blue-100/80 bg-white/90 px-5 py-3 shadow-[0_18px_52px_-28px_rgba(14,93,245,0.6)] backdrop-blur">
    <div class="flex items-center justify-between gap-4">
      <a href={homeHref} class="inline-flex items-center gap-3 text-slate-900 transition hover:text-blue-700">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-blue-600 text-sm font-bold text-white shadow-lg shadow-blue-200">AI</span>
        <span class="text-sm font-semibold uppercase tracking-[0.2em]">my-aicustom.com</span>
      </a>

      <div class="hidden items-center gap-7 md:flex">
        <a href={homeHref} class="text-[13px] font-semibold uppercase tracking-[0.14em] text-slate-600 transition hover:text-blue-700">Home</a>
        <a href={serviceHref} class="text-[13px] font-semibold uppercase tracking-[0.14em] text-slate-600 transition hover:text-blue-700">Service</a>
        <a href={adsHref} class="text-[13px] font-semibold uppercase tracking-[0.14em] text-slate-600 transition hover:text-blue-700">Landing Ads</a>
        <a href={blogHref} class="text-[13px] font-semibold uppercase tracking-[0.14em] text-slate-600 transition hover:text-blue-700">Blog</a>
        <a href={contactHref} class="inline-flex items-center rounded-full bg-blue-600 px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2">Konsultasi Gratis</a>
      </div>

      <div class="md:hidden">
        <button id="hamburger" class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-blue-100 text-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-300" aria-label="Toggle navigation">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden border-t border-blue-100/80 pt-3 mt-3 md:hidden">
      <a href={homeHref} class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-blue-50 hover:text-blue-700">Home</a>
      <a href={serviceHref} class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-blue-50 hover:text-blue-700">Service</a>
      <a href={adsHref} class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-blue-50 hover:text-blue-700">Landing Ads</a>
      <a href={blogHref} class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-blue-50 hover:text-blue-700">Blog</a>
      <a href={contactHref} class="mt-2 block rounded-full bg-blue-600 px-4 py-2 text-center text-sm font-semibold text-white transition hover:bg-blue-700">Konsultasi Gratis</a>
    </div>
  </nav>
</header>

<script>
  document.getElementById('hamburger')?.addEventListener('click', function () {
    const mobileMenu = document.getElementById('mobile-menu');
    if (mobileMenu) {
      mobileMenu.classList.toggle('hidden');
    }
  });
</script>
