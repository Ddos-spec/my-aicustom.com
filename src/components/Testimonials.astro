---
const testimonials = [
  {
    quote:
      '"Dalam enam minggu kami mengganti perutean manual dengan AI dan memotong waktu tunggu hingga setengahnya. Tim memandu kami melalui setiap sprint."',
    name: 'Ayu Rahman',
    role: 'Kepala Pengalaman Pelanggan, Lifepack',
    avatar: 'https://i.pravatar.cc/150?img=11',
  },
  {
    quote:
      '"Kampanye yang dulu membutuhkan sepuluh orang sekarang berjalan dengan dua orang. Pelaporan, tindak lanjut, dan eksperimen terjadi secara otomatis."',
    name: 'Hadi Prakoso',
    role: 'VP Pertumbuhan, Ekrut',
    avatar: 'https://i.pravatar.cc/150?img=22',
  },
  {
    quote:
      '"Templat tata kelola dan dukungan manajemen perubahan membuat tim kepatuhan kami percaya diri untuk menskalakan AI ke wilayah baru."',
    name: 'Nadya Santoso',
    role: 'Direktur Operasi, Datasintesa',
    avatar: 'https://i.pravatar.cc/150?img=36',
  },
];

const storyStats = [
  { value: '40%', label: 'Waktu respons turun' },
  { value: '2.8x', label: 'Kecepatan eksperimen naik' },
  { value: '99.3%', label: 'SLA otomatisasi terjaga' },
];
---
<section class="relative overflow-hidden bg-[#eaf4ff] py-24">
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_12%_12%,rgba(56,189,248,0.2),transparent_34%),radial-gradient(circle_at_92%_2%,rgba(59,130,246,0.18),transparent_30%)]"></div>
  </div>
  <div class="relative mx-auto max-w-screen-xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.25fr_0.75fr] lg:items-center">
      <div class="space-y-6">
        <span class="inline-flex items-center gap-2 rounded-full border border-sky-200 bg-white/80 px-5 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
          <span class="h-2 w-2 rounded-full bg-sky-500"></span>
          Cerita Klien
        </span>
        <h2 class="text-3xl font-semibold leading-tight text-slate-900 sm:text-4xl">Kemenangan otomatisasi dari tim lintas fungsi yang kami dukung</h2>
        <p class="text-slate-600">
          Umpan balik nyata dari para pemimpin pemasaran, operasi, dan produk yang membangun bersama kami. Setiap cerita menyoroti metrik yang mereka lacak dan ritual yang menjaga adopsi tetap tinggi.
        </p>
        <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
          {storyStats.map((item) => (
            <div class="rounded-2xl border border-sky-100 bg-white/90 px-5 py-4 shadow-[0_16px_44px_-30px_rgba(14,93,245,0.5)]">
              <p class="text-2xl font-semibold text-blue-700">{item.value}</p>
              <p class="mt-1 text-sm text-slate-600">{item.label}</p>
            </div>
          ))}
        </div>
        <a
          href="/contact/"
          class="inline-flex w-fit items-center justify-center gap-2 rounded-full bg-blue-600 px-6 py-3 text-sm font-semibold uppercase tracking-[0.24em] text-white transition hover:bg-blue-500"
        >
          Pesan panggilan penemuan
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="space-y-6">
        {testimonials.map((testimonial) => (
          <blockquote class="rounded-3xl border border-sky-100 bg-white/92 p-6 shadow-[0_24px_70px_-45px_rgba(37,99,235,0.45)]">
            <p class="text-lg text-slate-700">{testimonial.quote}</p>
            <footer class="mt-4 flex items-center gap-3">
              <img src={testimonial.avatar} alt={testimonial.name} loading="lazy" class="h-12 w-12 rounded-full object-cover" />
              <div class="text-sm text-slate-500">
                <p class="font-semibold text-slate-900">{testimonial.name}</p>
                <p>{testimonial.role}</p>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </div>
</section>
