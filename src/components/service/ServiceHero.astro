---
interface Props {
  heading: string;
  subheading: string;
  ctaLabel: string;
  ctaHref: string;
  imageSrc: string;
  imageAlt: string;
}

const { heading, subheading, ctaLabel, ctaHref, imageSrc, imageAlt } = Astro.props;
const contactHref = '/contact/';
---

<!-- Image assets used:
  - Hero illustration: https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1600&q=80
-->
<section class="relative overflow-hidden bg-sky-50 text-slate-900">
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_10%,rgba(56,189,248,0.22),transparent_34%),radial-gradient(circle_at_90%_0%,rgba(59,130,246,0.18),transparent_32%),linear-gradient(180deg,#edf7ff_0%,#f7fbff_55%,#ffffff_100%)]"></div>
  </div>
  <div class="relative mx-auto flex w-full max-w-6xl flex-col items-center gap-12 px-6 py-24 lg:flex-row lg:items-center lg:py-28">
    <div class="w-full lg:w-1/2">
      <span class="inline-flex items-center rounded-full border border-sky-200 bg-white/80 px-4 py-1 text-sm font-semibold uppercase tracking-widest text-sky-700">Solusi AI Terintegrasi</span>
      <h1 class="mt-6 text-4xl font-bold leading-tight tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">{heading}</h1>
      <p class="mt-5 text-lg text-slate-600 sm:text-xl">{subheading}</p>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center rounded-full bg-blue-600 px-7 py-3 text-base font-semibold text-white shadow-lg shadow-blue-200/80 transition hover:-translate-y-0.5 hover:bg-blue-500"
        >
          {ctaLabel}
        </a>
        <a href={contactHref} class="inline-flex items-center text-sm font-semibold text-blue-700 hover:text-blue-800">
          Konsultasi gratis via email
        </a>
      </div>
    </div>
    <div class="w-full max-w-2xl lg:w-1/2">
      <img
        src={imageSrc}
        alt={imageAlt}
        loading="lazy"
        class="w-full rounded-3xl object-cover shadow-2xl shadow-sky-500/20 ring-1 ring-sky-200/70"
      />
    </div>
  </div>
</section>
