---
import { workflowSteps } from '../../data/workflowSteps';
---

<section class="bg-slate-50 py-24">
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-16 px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="inline-flex items-center rounded-full bg-sky-100 px-4 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">
        Workflow
      </span>
      <h2 class="mt-6 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Cara Kami Bekerja</h2>
      <p class="mt-4 text-lg text-slate-600">
        Pendekatan kolaboratif untuk memastikan setiap implementasi AI memberikan ROI yang terukur.
      </p>
    </div>
    <div class="grid gap-8 md:grid-cols-3">
      {workflowSteps.map((step) => (
        <div class="flex h-full flex-col rounded-3xl border border-slate-200/80 bg-white p-8 shadow-lg shadow-slate-900/5 transition hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold uppercase tracking-wide text-sky-600">{step.phase}</span>
            <span class="text-3xl font-bold text-slate-300">{step.id}</span>
          </div>
          <h3 class="mt-6 text-xl font-semibold text-slate-900">{step.title}</h3>
          <p class="mt-3 text-base text-slate-600">{step.description}</p>
        </div>
      ))}
    </div>
    <div class="text-center">
      <a
        href="/konsultasi"
        class="inline-flex items-center justify-center rounded-full bg-slate-900 px-7 py-3 text-base font-semibold text-white shadow-lg shadow-slate-900/30 transition hover:-translate-y-0.5 hover:bg-slate-700:bg-sky-400"
      >
        Mulai Diskusi Proyek
      </a>
    </div>
  </div>
</section>
